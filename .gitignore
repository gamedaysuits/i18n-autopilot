i18n-rosetta.config.json
.i18n-rosetta.lock

# Research vault
.vault/

# Coverage and build artifacts
coverage/
*.tgz

# Test temp directories
test/fixtures/_tmp_*

# Benchmark data — large scraped corpora and results (kept locally, not in git/npm)
test/benchmark/
.rosetta/

# Supabase local temp files (machine-generated, per-environment)
supabase/.temp/

# Co-located ecosystem projects (separate git repos, not part of rosetta)
crk-translate/

# One-time dev scripts (already run, not user-facing)
scripts/split-cards-to-tiers.mjs
scripts/enrich-cards-from-cldr.mjs
scripts/enrich-tier3-batch.mjs

