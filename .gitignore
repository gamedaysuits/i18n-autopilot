.i18n-rosetta-content.lock

# Research vault
.vault/

# Coverage and build artifacts
coverage/
*.tgz

# Test temp directories
test/fixtures/_tmp_*

# Benchmark data — large scraped corpora and results (kept locally, not in git/npm)
test/benchmark/
.rosetta/

# Supabase local temp files (machine-generated, per-environment)
supabase/.temp/

# Co-located ecosystem projects (separate git repos, not part of rosetta)
crk-translate/
gds-mt-eval-harness/

# One-time dev scripts (already run, not user-facing)
scripts/split-cards-to-tiers.mjs
scripts/enrich-cards-from-cldr.mjs
scripts/enrich-tier3-batch.mjs

# ── Internal / non-public files ─────────────────────────────────────
# These exist locally for project development but should NOT be in the
# public GitHub repo. They contain SaaS planning, pricing strategy,
# competitive details, and internal marketing assets.

# Confidential internal docs — financial models, cap tables, investor materials
internal/

# Internal planning docs have been moved to crk-translate/docs/internal/ (private repo).
# Nothing to gitignore here — they no longer exist in this repo.

# README translation scaffolding — internal tooling for dogfooding rosetta on its own README.
# The finished translations (docs/README.*.md) are public; the build pipeline isn't.
docs/readme-src/
docs/readme-locales/
docs/readme-i18n.config.json

# Marketing assets — promo videos, logo animations, walkthrough HTML.
# Not part of the OSS tool. Keep locally for campaigns.
marketing/

# Local-only research/presentation assets — never commit
