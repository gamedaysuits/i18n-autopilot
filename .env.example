# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# DeepL API Key (for 'deepl' method)
# Ends with :fx for Free plan, or standard for Pro plan
DEEPL_API_KEY=your-deepl-key-here

# Microsoft Translator API (for 'microsoft-translator' method)
MICROSOFT_TRANSLATOR_API_KEY=your-ms-key-here
# Optional region parameter (e.g. westeurope, centralus)
MICROSOFT_TRANSLATOR_REGION=global

# LibreTranslate API (for 'libretranslate' method)
# Optional key and configurable base URL
LIBRETRANSLATE_API_URL=http://localhost:5000/translate
LIBRETRANSLATE_API_KEY=

# Direct LLM Provider APIs
# OpenAI API Key (for 'openai' method)
OPENAI_API_KEY=
# Anthropic API Key (for 'anthropic' method)
ANTHROPIC_API_KEY=
# Google Gemini API Key (for 'gemini' method)
GEMINI_API_KEY=
